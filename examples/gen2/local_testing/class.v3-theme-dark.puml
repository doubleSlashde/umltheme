@startuml v3-theme-dark
!theme dark from ../../../doubleslash/v3
left to right direction

title UML Theme v3 — Dark Mode Smoke Test

class Customer {
  +name: String
  +placeOrder(): Order
}

interface "Payment API" as Payment <<interface>>

note left of Customer
  Covers global selectors:
  element, note, arrow,
  group, legend, title
end note

together {
  class Order {
    +total: Decimal
  }
  class "Line Item" as LineItem
}

Customer --> Order : places
Order --> Payment : uses

legend right
  |= Token |= Selector |
  | Canvas | root |
  | Elements | element |
  | Interface | .interface |
  | Container | group |
endlegend

footer Smoke test for puml-theme-dark.puml (v3)

@enduml
