---
name: light
display_name: doubleSlash (Light)
description: Light-mode — CSS-style theme for canvas, elements, arrows, and meta elements
author: doubleSlash
release:
license: MIT
version: 3.0.0
source: https://github.com/doubleSlashde/umltheme
inspiration: https://plantuml.com/de/style
---

skinparam useBetaStyle false
skinparam dpi 100
skinparam Shadowing false
skinparam BackGroundColor #FFFFFF
skinparam DefaultTextAlignment center
'skinparam linetype polyline
' Direction is not set globally in v3 theme.
' Set "top to bottom direction" or "left to right direction"
' in the concrete diagram where the diagram type supports it.

' Activity — legacy only (no CSS selector for start/stop, fork/join bar, swimlane)
skinparam conditionStyle diamond
skinparam activity {
  StartColor            #515151
  EndColor              #515151
  BarColor              #6B9714
}
skinparam swimlane {
  TitleFontColor        #000000
  TitleFontSize         16
  TitleBackgroundColor  #F8F8F8
  BorderColor           #C6C6C6
  BorderThickness       1
}

' State — legacy only (StartColor, EndColor, AttributeFont*; no CSS equivalent)
skinparam state {
  StartColor            #515151
  EndColor              #515151
  AttributeFontColor    #000000
  AttributeFontSize     11
}

hide circle
hide empty members
hide stereotype
!ifndef $FONT_NAME
  !$FONT_NAME = "Helvetica"
!endif
<style>
  root {
    BackGroundColor #FFFFFF
    FontSize 12
  }

  element {
    LineColor             #00759E
    LineThickness         1
    'LineStyle             solid
    FontName              Helvetica
    FontSize              12
    FontColor             #000000
    FontStyle             normal
    Shadowing             0
    RoundCorner           16
    Padding               4
    Margin                4 32 4 32
    HorizontalAlignment   center
  }

  arrow {
    LineColor             #7A7A7A
    LineThickness         1.5
    LineStyle             solid
    FontName              Helvetica
    FontSize              11
    FontColor             #000000
    FontStyle             normal
  }

  note {
    BackGroundColor       transparent
    LineColor             #7A7A7A
    FontName              Helvetica
    FontSize              11
    FontColor             #000000
    FontStyle             normal
    Shadowing             0
    HorizontalAlignment   left
  }

  legend {
    BackGroundColor       transparent
    LineColor             #7A7A7A
    FontName              Helvetica
    FontSize              11
    FontColor             #000000
    FontStyle             normal
    Shadowing             0
  }

  title {
    BackGroundColor       transparent
    FontName              Helvetica
    FontSize              28
    FontColor             #000000
    FontStyle             normal
    BorderRoundCorner     16
    Shadowing             0
  }

  caption {
    BackGroundColor       transparent
    FontName              Helvetica
    FontSize              11
    FontColor             #000000
    FontStyle             normal
    Shadowing             0
  }

  footer {
    BackGroundColor       transparent
    FontName              Helvetica
    FontSize              11
    FontColor             #000000
    FontStyle             normal
    Shadowing             0
  }

  stereotype {
    FontName              Helvetica
    FontSize              11
    FontColor             #000000
    FontStyle             normal
  }

  group {
    BackGroundColor       #F8F8F8
    LineColor             #00759E
    LineThickness         1
    LineStyle             solid
    FontName              Helvetica
    FontSize              12
    FontColor             #000000
    FontStyle             normal
    Shadowing             0
    RoundCorner           16
    Padding               4
  }
  database {
    BackGroundColor       #D7E9F4
    FontSize              12
    LineThickness         1
    LineColor             #C6C6C6
  }
  usecase {
    BackGroundColor       #D7E9F4
    LineThickness         0
  }
  rectangle {
    BackGroundColor       #F0F8FF
    LineThickness         0
    FontSize              14
  }
  actor {
    BackGroundColor     #C6C6C6
    LineColor           #C6C6C6
    LineThickness       3
    FontColor           #6D6D6D
    FontSize            14
  }
  separator {
    BackGroundColor     #F8F8F8
    LineColor           #F8F8F8
    LineThickness 0
  }
  package {
    BackGroundColor     #F0F8FF
    LineThickness       0
    FontSize            14
    FontStyle           normal
  }
  .external {
      BackGroundColor     #F8F8F8
      LineThickness       1
      LineColor           #7A7A7A
  }  
  .interface {
    BackGroundColor       #00A5E1
    LineColor             #00759E
    LineThickness         2
    FontColor             #000000
  }
  .interface.external {
    BackGroundColor       #7A7A7A
    LineColor             #7A7A7A
  }
  .context {
    BackGroundColor       #FFFFFF
    LineColor             #00759E
    LineThickness         1
    LineStyle             solid
    FontColor             #000000
    FontStyle             bold
    FontSize              12
  }
  .container {
    BackGroundColor       #EEF8FE
    LineColor             #C6C6C6
    LineThickness         1
    LineStyle             solid
    FontColor             #000000
    FontSize              12
  }
  .component {
    BackGroundColor       #D7E9F4
    LineThickness         0
    FontColor             #000000
    FontSize              12
  }
  .module {
    BackGroundColor       #AFC1C7
    LineThickness         0
    FontColor             #000000
    FontSize              12
  }
  .code {
    BackGroundColor       #84999F
    LineThickness         0
    FontColor             #FFFFFF
    FontSize              12
  }
  .database.external {
    BackGroundColor       #F8F8F8
    LineColor             #7A7A7A
    LineThickness         1
  }
' =============================================================
' Ende — Globale Defaults (Light Mode)
' =============================================================

  sequenceDiagram {
    participant {
      BackGroundColor     #D7E9F4
      LineColor           #00759E
      LineThickness       0
      Margin              4 32
      Padding             16 16
    }

    group {
      BackGroundColor     #F8F8F8
      LineColor           #7A7A7A
      Padding             32
    }

    box {
      BackGroundColor     #F8F8F8
      LineColor           #7A7A7A
      Padding             32
    }
  }

  activityDiagram {
    activity {
      BackGroundColor     #D7E9F4
    }

    activityBar {
      BackGroundColor     #6B9714
      LineThickness       2
    }

    start {
      BackGroundColor #515151
      LineColor #515151
    }

    diamond {
      BackGroundColor     #00A5E1
      LineColor           #00759E
      FontColor           #000000
      FontSize            11
    }

    partition {
      LineColor           #00759E
      FontColor           #00759E
      BackGroundColor     transparent
    }
  }

  stateDiagram {
    state {
      BackGroundColor     #D7E9F4
    }

    diamond {
      BackGroundColor     #00A5E1
      LineColor           #00759E
      FontColor           #000000
      FontSize            11
    }

    activityBar {
      BackGroundColor     #6B9714
      LineThickness       2
    }
    start {
      BackGroundColor #515151
      LineColor #515151
    }
    end {
      BackGroundColor #515151
      LineColor #515151
    }
  }
  componentDiagram {
    interface {
      BackGroundColor       #00A5E1
      LineThickness         0
      FontColor             #000000
      FontSize              12
      IconColor             #000000
    }
    component {
      BackGroundColor       #D7E9F4
      LineThickness         0
      FontColor             #000000
      FontSize              12
    }

  }
</style>