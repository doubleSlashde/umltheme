---
name: dark
display_name: doubleSlash (Dark)
description: Dark-mode — CSS-style theme for canvas, elements, arrows, and meta elements
author: doubleSlash
release:
license: MIT
version: 3.0.0
source: https://github.com/doubleSlashde/umltheme
inspiration: https://plantuml.com/de/style
---

skinparam useBetaStyle false
skinparam dpi 100
skinparam Shadowing false
skinparam BackgroundColor #15202B
skinparam DefaultTextAlignment center
'skinparam linetype polyline
' Direction is not set globally in v3 theme.
' Set "top to bottom direction" or "left to right direction"
' in the concrete diagram where the diagram type supports it.

' Activity — legacy only (no CSS selector for start/stop, fork/join bar, swimlane)
skinparam conditionStyle diamond
skinparam activity {
  StartColor            #CCCCCC
  EndColor              #CCCCCC
  BarColor              #B9D478
}
skinparam swimlane {
  TitleFontColor        #D7E9F4
  TitleFontSize         16
  TitleBackgroundColor  #2D2D2D
  BorderColor           #B6B6B6
  BorderThickness       1
}

' State — legacy only (StartColor, EndColor, AttributeFont*; no CSS equivalent)
skinparam state {
  StartColor            #CCCCCC
  EndColor              #CCCCCC
  AttributeFontColor    #D7E9F4
  AttributeFontSize     11
}

hide circle
hide empty members
hide stereotype

<style>
  root {
    BackGroundColor #15202B
    FontSize 12
  }

  element {
    LineColor             #77DDFF
    LineThickness         1
    'LineStyle             solid
    FontName              Helvetica
    FontSize              12
    FontColor             #D7E9F4
    FontStyle             normal
    Shadowing             0
    RoundCorner           16
    Padding               4
    HorizontalAlignment   center
  }

  arrow {
    LineColor             #7A7A7A
    LineThickness         1.5
    LineStyle             solid
    FontName              Helvetica
    FontSize              11
    FontColor             #D7E9F4
    FontStyle             normal
  }

  note {
    BackGroundColor       transparent
    LineColor             #7A7A7A
    FontName              Helvetica
    FontSize              11
    FontColor             #D7E9F4
    FontStyle             normal
    Shadowing             0
    HorizontalAlignment   left
  }

  legend {
    BackGroundColor       transparent
    LineColor             #7A7A7A
    FontName              Helvetica
    FontSize              11
    FontColor             #D7E9F4
    FontStyle             normal
    Shadowing             0
  }

  title {
    BackGroundColor       transparent
    FontName              Helvetica
    FontSize              28
    FontColor             #D7E9F4
    FontStyle             normal
    BorderRoundCorner     16
    Shadowing             0
  }

  caption {
    BackGroundColor       transparent
    FontName              Helvetica
    FontSize              11
    FontColor             #D7E9F4
    FontStyle             normal
    Shadowing             0
  }

  footer {
    BackGroundColor       transparent
    FontName              Helvetica
    FontSize              11
    FontColor             #D7E9F4
    FontStyle             normal
    Shadowing             0
  }

  stereotype {
    FontName              Helvetica
    FontSize              11
    FontColor             #D7E9F4
    FontStyle             normal
  }

  group {
    BackGroundColor       #2D2D2D
    LineColor             #77DDFF
    LineThickness         1
    LineStyle             solid
    FontName              Helvetica
    FontSize              12
    FontColor             #D7E9F4
    FontStyle             normal
    Shadowing             0
    RoundCorner           16
    Padding               4
  }
  database {
    BackGroundColor       #22303C
    LineColor             #7A7A7A
    LineThickness         1
    FontSize              12
  }
  usecase {
    BackGroundColor       #22303C
    LineThickness         0
  }
  rectangle {
    BackGroundColor       #3A3A3A
    LineThickness         0
    FontSize              14
  }
  actor {
    BackGroundColor     #B6B6B6
    LineColor           #B6B6B6
    LineThickness       3
    FontColor           #AFC1C7
    FontSize            14
  }
  separator {
    BackGroundColor     #2D2D2D
    LineColor           #2D2D2D
    LineThickness 0
  }

  package {
    BackGroundColor     #3A3A3A
    LineThickness       0
    FontSize            14
    FontStyle           normal
  }
  .external {
      BackGroundColor     #2D2D2D
      LineThickness       0
  }
  .interface {
    BackGroundColor       #00A5E1
    FontColor             #D7E9F4
  }
  .interface.external {
    BackGroundColor       #7A7A7A
    LineColor             #7A7A7A
  }
  .context {
    BackGroundColor       #2A2A2A
    LineColor             #77DDFF
    LineThickness         1
    LineStyle             solid
    FontColor             #D7E9F4
    FontStyle             bold
    FontSize              12
  }
  .container {
    BackGroundColor       #353535
    LineColor             #B6B6B6
    LineThickness         1
    LineStyle             solid
    FontColor             #D7E9F4
    FontSize              12
  }
  .component {
    BackGroundColor       #404040
    LineThickness         0
    FontColor             #D7E9F4
    FontSize              12
  }
  .module {
    BackGroundColor       #4A4A4A
    LineThickness         0
    FontColor             #D7E9F4
    FontSize              12
  }
  .code {
    BackGroundColor       #555555
    LineThickness         0
    FontColor             #FFFFFF
    FontSize              12
  }
  .database.external {
    LineColor             #7A7A7A
    LineThickness         1
  }
' =============================================================
' Ende — Globale Defaults (Dark Mode)
' =============================================================

  sequenceDiagram {
    participant {
      BackGroundColor     #22303C
      LineColor           #77DDFF
      LineThickness       0
      Margin              4 32
      Padding             16 16
    }

    group {
      BackGroundColor     #2D2D2D
      LineColor           #7A7A7A
      Padding             32
    }

    box {
      BackGroundColor     #2D2D2D
      LineColor           #7A7A7A
      Padding             32
    }
  }

  activityDiagram {
    activity {
      BackGroundColor     #22303C
    }

    activityBar {
      BackGroundColor     #B9D478
      LineThickness       2
    }
    
    start {
      BackgroundColor #CCCCCC
      LineColor #CCCCCC
    }

    diamond {
      BackGroundColor     #00A5E1
      LineColor           #77DDFF
      FontColor           #000000
      FontSize            11
    }

    partition {
      LineColor           #77DDFF
      FontColor           #77DDFF
      BackGroundColor     transparent
    }
  }

  stateDiagram {
    state {
      BackGroundColor     #22303C
    }

    diamond {
      BackGroundColor     #00A5E1
      LineColor           #77DDFF
      FontColor           #000000
      FontSize            11
    }

    activityBar {
      BackGroundColor     #B9D478
      LineThickness       2
    }

    start {
      BackGroundColor #CCCCCC
      LineColor #CCCCCC
    }

    end {
      BackGroundColor #CCCCCC
      LineColor #CCCCCC
    }
  }
  componentDiagram {
    interface {
      BackGroundColor       #00A5E1
      FontColor             #D7E9F4
      LineThickness         0
      FontSize              12
    }
    component {
      BackGroundColor       #404040
      LineThickness         0
      FontColor             #D7E9F4
      FontSize              12
    }
  }
</style>
