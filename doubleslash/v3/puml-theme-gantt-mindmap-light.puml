---
name: gantt-mindmap-light
display_name: doubleSlash (Gantt & Mindmap Light)
description: Light-mode — CSS-style theme for Gantt & Mindmap
author: doubleSlash
release:
license: MIT
version: 3.0.0
source: https://github.com/doubleSlashde/umltheme
inspiration: https://plantuml.com/de/style
---

skinparam useBetaStyle false
skinparam dpi 100
skinparam Shadowing false
skinparam BackgroundColor #FFFFFF
skinparam DefaultTextAlignment center

<style>
  root {
    BackGroundColor #FFFFFF
    FontSize 12
  }

  element {
    LineColor             #00759E
    LineThickness         1
    'LineStyle             solid
    FontName              Helvetica
    FontSize              12
    FontColor             #000000
    FontStyle             normal
    Shadowing             0
    RoundCorner           16
    Padding               4
    Margin                4 32 4 32
    HorizontalAlignment   center
  }

  arrow {
    LineColor             #7A7A7A
    LineThickness         1.5
    LineStyle             solid
    FontName              Helvetica
    FontSize              11
    FontColor             #000000
    FontStyle             normal
  }

  note {
    BackGroundColor       transparent
    LineColor             #7A7A7A
    FontName              Helvetica
    FontSize              11
    FontColor             #000000
    FontStyle             normal
    Shadowing             0
    HorizontalAlignment   left
    Padding               4 4 4 4
    Margin                4 4 4 4
  }

  legend {
    BackGroundColor       transparent
    LineColor             #7A7A7A
    FontName              Helvetica
    FontSize              11
    FontColor             #000000
    FontStyle             normal
    Shadowing             0
  }

  title {
    BackGroundColor       transparent
    FontName              Helvetica
    FontSize              28
    FontColor             #000000
    FontStyle             normal
    BorderRoundCorner     16
    Shadowing             0
  }

  caption {
    BackGroundColor       transparent
    FontName              Helvetica
    FontSize              11
    FontColor             #000000
    FontStyle             normal
    Shadowing             0
  }

  footer {
    BackGroundColor       transparent
    FontName              Helvetica
    FontSize              11
    FontColor             #000000
    FontStyle             normal
    Shadowing             0
  }

  stereotype {
    FontName              Helvetica
    FontSize              11
    FontColor             #000000
    FontStyle             normal
  }

  group {
    BackGroundColor       #F8F8F8
    LineColor             #00759E
    LineThickness         1
    LineStyle             solid
    FontName              Helvetica
    FontSize              12
    FontColor             #000000
    FontStyle             normal
    Shadowing             0
    RoundCorner           16
    Padding               4
  }
  mindmapDiagram {
    node {
      BackGroundColor       #D7E9F4
      FontColor             #000000
      FontSize              12
      Padding               10
      Margin                10
      LineColor             transparent
      LineThickness         0
    }

    rootNode {
      BackGroundColor       #00A5E1
      FontColor             #FFFFFF
      FontSize              12
      FontStyle             bold
      Padding               10
      Margin                10
      LineColor             transparent
      LineThickness         0
    }

    leafNode {
      BackGroundColor       #FFFFFF
      FontColor             #000000
      FontSize              11
      Padding               5
      Margin                5
      LineColor             transparent
      LineThickness         0
    }

    arrow {
      LineColor             #7A7A7A
      LineThickness         1.5
    }
  }

  wbsDiagram {
    node {
      BackGroundColor       #D7E9F4
      FontColor             #000000
      FontSize              12
      Padding               10
      Margin                10
      LineColor             #00759E
      LineThickness         1
    }

    rootNode {
      BackGroundColor       #00A5E1
      FontColor             #FFFFFF
      FontSize              12
      FontStyle             bold
      Padding               10
      Margin                10
      LineColor             #00759E
      LineThickness         1
    }

    leafNode {
      BackGroundColor       #FFFFFF
      FontColor             #000000
      FontSize              11
      Padding               5
      Margin                5
      LineColor             #00759E
      LineThickness         1
    }

    arrow {
      LineColor             #7A7A7A
      LineThickness         1.5
    }
  }

  ganttDiagram {
    task {
      FontName              Helvetica
      FontSize              12
      FontColor             #000000
      FontStyle             normal
      BackGroundColor       #D7E9F4
      LineColor             #D7E9F4
      RoundCorner           6
      Margin                0
      Padding               3
      HorizontalAlignment   left
      unstarted {
        BackGroundColor     #F8F8F8
        LineColor           #C6C6C6
      }
      undone {
        BackGroundColor     #C63328
        LineColor           #C63328
        FontColor           #FFFFFF
      }
    }

    timeline {
      FontName              Helvetica
      FontSize              12
      FontColor             #000000
      BackGroundColor       #F8F8F8
    }

    milestone {
      FontColor             #000000
      FontSize              12
      FontStyle             normal
      BackGroundColor       #00759E
      LineColor             #00759E
      LineThickness         15
      Margin                5
    }

    note {
      FontColor             #000000
      FontSize              10
      LineColor             #C6C6C6
      Margin                4 4 16 4
    }

    closed {
      BackGroundColor       #6B9714
      LineColor             #6B9714
      FontColor             #FFFFFF
    }

    arrow {
      LineColor             #7A7A7A
      LineStyle             solid
      LineThickness         1.5
      FontName              Helvetica
      FontColor             #000000
      FontSize              12
    }

    separator {
      LineColor             #7A7A7A
      LineThickness         1
      FontSize              12
      FontColor             #000000
      Margin                5
      Padding               5
    }
  }
</style>